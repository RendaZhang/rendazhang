---
import { BaseLayout } from '../layouts';
import {
  SITE_BASE_URL,
  DOCS_PAGE_PATH,
  STYLE_PATHS,
  VIEWPORT_NO_ZOOM,
  PAGE_TITLES,
  DOCS_DESCRIPTION,
  DOC_CONTENT,
  buildDocsStructuredDataJson
} from '../constants';
import { DocsEffects } from '../components/sections';
import { getCurrentLang } from '../utils';
import { marked } from 'marked';

const langDefault = getCurrentLang();
const langKey = langDefault.startsWith('zh') ? 'zh' : 'en';
const titleZh = PAGE_TITLES.DOCS_ZH;
const titleEn = PAGE_TITLES.DOCS_EN;
const title = langKey === 'zh' ? titleZh : titleEn;
const docsHtmlZh = marked.parse(DOC_CONTENT.README_ZH) as string;
const docsHtmlEn = marked.parse(DOC_CONTENT.README_EN) as string;
---

<BaseLayout
  lang={langDefault}
  titleZh={titleZh}
  titleEn={titleEn}
  title={title}
  description={DOCS_DESCRIPTION}
  viewport={VIEWPORT_NO_ZOOM}
  canonical={`${SITE_BASE_URL}${DOCS_PAGE_PATH}/`}
  structuredDataJson={buildDocsStructuredDataJson()}
  extraStyles={[
    STYLE_PATHS.GITHUB_CODE_HIGHLIGHT,
    STYLE_PATHS.GITHUB_MARKDOWN_LIGHT,
    STYLE_PATHS.DOCS,
    STYLE_PATHS.MARKDOWN_DARK_MODE
  ]}
  bodyClass="docs-page"
  mainClass="c-main-content c-docs-main"
  og={{
    title: PAGE_TITLES.DOCS_EN,
    description: DOCS_DESCRIPTION,
    url: `${SITE_BASE_URL}${DOCS_PAGE_PATH}/`
  }}
  metaLanguage="en, zh-CN"
>
  <div id="content-zh" class="is-lang-zh c-markdown-body" set:html={docsHtmlZh} />
  <div id="content-en" class="is-lang-en c-markdown-body" set:html={docsHtmlEn} />
  <Fragment slot="bodyEnd">
    <DocsEffects client:load />
  </Fragment>
</BaseLayout>
